# Copy this file to ".env" and fill in your key, OR export the variable in your
# shell. In CI, set this as a GitHub Secret named GOOGLE_MAPS_API_KEY instead.
GOOGLE_MAPS_API_KEY=your-demo-key-here

# Web app only (set these as Environment Variables in the Vercel dashboard):
# Shared password that gates every request to the web app.
APP_PASSWORD=choose-a-shared-password
# Optional web-app tuning.
# MAX_ROWS=750
# PLACES_MAX_WORKERS=8
